// Membership LMS data model.
// Keystone decisions baked in here:
//  - UserLevel join carries `source` (stripe|manual) and `status`, so a manual
//    grant and a paid subscription for the same level coexist without conflict.
//  - A course unlocks if the user holds ANY active UserLevel among the course's
//    assigned levels (CourseLevel join).
//  - mailchimpTag (not a separate audience) per level — one audience, tag per level.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Identity ----------

model User {
  id               String          @id @default(cuid())
  email            String          @unique
  username         String          @unique
  passwordHash     String
  firstName        String?         // optional profile fields (admin-managed)
  lastName         String?
  phone            String?
  wpId             Int?            @unique // original WordPress user ID, for migration reconciliation
  stripeCustomerId String?         @unique // cus_… on the SAME Stripe account
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  emailOptOut      Boolean         @default(false) // set by Mailchimp unsubscribe webhook

  levels    UserLevel[]
  progress  LessonProgress[]
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  EDITOR // can manage courses/lessons but not billing keys
}

model Admin {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  role         AdminRole @default(ADMIN)
  // Per-section CRUD permissions for non-super admins, shape:
  // { [section]: { create?, read?, edit?, delete? } }. SUPER_ADMIN ignores this
  // (implicit full access). Enforced by PermissionsGuard; edited by super admins.
  permissions  Json      @default("{}")
  // Per-admin UI preferences (personal, not access-controlling), shape:
  // { menuOrder?: string[] } — the admin's custom sidebar ordering by nav key.
  // Self-service via PATCH /auth/admin/prefs; every admin manages their own.
  prefs        Json      @default("{}")
  createdAt    DateTime  @default(now())

  posts Post[]
  pages Page[]
  media MediaAsset[]
  notificationReads AdminNotificationRead[]
}

// ---------- Membership levels ----------

enum LevelType {
  PAID
  FREE
  MANUAL
}

model Level {
  id                    String      @id @default(cuid())
  name                  String
  slug                  String?     @unique // pretty checkout URL key: /checkout/<slug> (admin-editable)
  published             Boolean     @default(false) // show this class as a tile on the member dashboard
  type                  LevelType   @default(PAID)
  mailchimpTags         String[]    @default([]) // tag names applied within the audience
  mailchimpAudienceId   String?     // Mailchimp list this level subscribes members to (falls back to the global Settings audience)
  mailchimpAudienceName String?     // cached name for admin display
  stripeProductId       String?     // prod_… for PAID levels
  // ----- MasterClass-style landing-page fields (all optional) -----
  imageUrl              String?     // hero/cover image for the class page
  description           String?     // marketing description
  trailerUrl            String?     // trailer: Vimeo/MP4 URL or a Gallery video URL
  skills                Json        @default("[]") // [{ title, imageUrl }] — "Skills You'll Learn"
  featuredCourseId      String?     // course whose lessons appear as the curriculum
  createdAt             DateTime    @default(now())

  prices         Price[]
  userLevels     UserLevel[]
  courseLevels   CourseLevel[]
  categories     LevelCategory[]
  featuredCourse Course?         @relation("ClassFeaturedCourse", fields: [featuredCourseId], references: [id], onDelete: SetNull)
}

model Price {
  id            String   @id @default(cuid())
  levelId       String
  level         Level    @relation(fields: [levelId], references: [id], onDelete: Cascade)
  stripePriceId String   @unique // price_…
  interval      String   // "month" | "year"
  amount        Int      // minor units (cents)
  currency      String   @default("usd")
  active        Boolean  @default(true)
  // Installment plan: bill this many times, then the member keeps the level for
  // life (the webhook sets UserLevel.lifetime and cancels the sub). null = an
  // ongoing subscription that bills until canceled.
  installments  Int?
}

enum UserLevelSource {
  STRIPE
  MANUAL
}

enum UserLevelStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
  PAUSED // billing paused — access suspended but resumable (unlike CANCELED)
}

model UserLevel {
  id                  String          @id @default(cuid())
  userId              String
  user                User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  levelId             String
  level               Level           @relation(fields: [levelId], references: [id], onDelete: Cascade)
  source              UserLevelSource
  status              UserLevelStatus @default(ACTIVE)
  // Once true the grant is permanent (a paid-in-full installment plan converted
  // to lifetime) and Stripe reconciliation will never revoke it.
  lifetime            Boolean         @default(false)
  stripeSubItemId     String?         // si_… when source = STRIPE
  expiresAt           DateTime?       // for manual grants or period-end access
  grantedAt           DateTime        @default(now())

  @@unique([userId, levelId, source])
  @@index([userId])
  @@index([levelId])
}

// Admin-managed grouping for membership levels ("Classes"). Many-to-many: a
// level can belong to several categories. Admin-only organization — not shown
// to members. (Separate from the blog's PostCategory.)
model LevelCategory {
  id     String  @id @default(cuid())
  name   String
  order  Int     @default(0)
  levels Level[]
}

// ---------- LMS content ----------

model Course {
  id            String        @id @default(cuid())
  title         String
  description   String?
  thumbnailUrl  String?       // squared thumbnail shown on course cards
  coverImageUrl String?       // wide cover/hero image shown on the course page
  order         Int           @default(0)
  createdAt     DateTime      @default(now())

  lessons          Lesson[]
  courseLevels     CourseLevel[]
  featuredInLevels Level[]       @relation("ClassFeaturedCourse")
}

// Many-to-many: a course is accessible to any of these levels.
model CourseLevel {
  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  levelId  String
  level    Level  @relation(fields: [levelId], references: [id], onDelete: Cascade)

  @@id([courseId, levelId])
}

model Lesson {
  id           String          @id @default(cuid())
  courseId     String
  course       Course          @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title        String
  content      String?         // markdown / rich text — doubles as the lesson description/body
  thumbnailUrl String?         // lesson thumbnail
  muxAssetId   String?         // managed video; playback via signed URL (prod)
  videoUrl     String?         // direct video URL (e.g. sample MP4); plays without Mux signing
  durationSeconds Int?         // lesson length in seconds (admin enters mm:ss); drives the curriculum total
  order        Int             @default(0)
  createdAt    DateTime        @default(now())

  progress LessonProgress[]
  notes    LessonNote[]
}

model LessonProgress {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId    String
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  completedAt DateTime @default(now())

  @@unique([userId, lessonId])
}

// Downloadable attachments for a lesson (PDFs, docs, etc.). Files live OUTSIDE
// the public images dir and are streamed only through an access-checked
// endpoint, so a locked course never leaks its materials.
model LessonNote {
  id           String   @id @default(cuid())
  lessonId     String
  lesson       Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  filename     String   // stored filename on disk (timestamp-based, unique)
  originalName String   // original upload name (shown to member; used as download filename)
  mimeType     String
  size         Int      // bytes
  order        Int      @default(0)
  createdAt    DateTime @default(now())

  @@index([lessonId])
}

// ---------- Billing mirror & settings ----------

enum SubStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  UNPAID
  INCOMPLETE
  PAUSED // pause_collection set — billing paused, access suspended
}

// Local mirror of Stripe subscriptions, kept current by webhooks.
model SubscriptionMirror {
  id                 String    @id @default(cuid())
  stripeSubId        String    @unique // sub_…
  stripeCustomerId   String
  status             SubStatus
  currentPeriodEnd   DateTime?
  cancelAtPeriodEnd  Boolean   @default(false)
  updatedAt          DateTime  @updatedAt
}

// Encrypted integration secrets (Stripe/Mailchimp). Values stored encrypted at
// rest; never returned to any client — admin UI is write-only for secrets.
model Setting {
  key       String   @id // e.g. "stripe.secretKey", "stripe.webhookSecret", "mailchimp.apiKey"
  value     String   // ciphertext
  updatedAt DateTime @updatedAt
}

// ---------- Blog ----------
// Public-facing marketing/news content. Unlike LMS courses, posts have no
// level gating: PUBLISHED posts are readable by anyone (no login). Drafts are
// admin-only. Blog taxonomy (PostCategory) is intentionally separate from the
// course Category so the two never couple.

enum PostStatus {
  DRAFT
  PUBLISHED
}

model PostCategory {
  id    String @id @default(cuid())
  name  String
  slug  String @unique
  order Int    @default(0)
  posts Post[]
}

model Post {
  id            String         @id @default(cuid())
  slug          String         @unique // URL key: /blog/:slug
  title         String
  excerpt       String? // short summary for cards + meta description
  content       String         @default("") // sanitized HTML (rich text)
  coverImageUrl String? // featured image (URL); used as hero + og:image
  status        PostStatus     @default(DRAFT)
  publishedAt   DateTime? // set when first published; drives public ordering
  authorId      String?
  author        Admin?         @relation(fields: [authorId], references: [id], onDelete: SetNull)
  categories    PostCategory[] // many-to-many: a post can be in several categories
  tags          String[]       @default([])
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([status, publishedAt])
}

// ---------- CMS Pages ----------
// Visual page-builder content (Puck). Like blog posts, PUBLISHED pages are
// public (no login) and drafts are admin-only. `data` is the Puck document
// (JSON) rendered by shared React block components in @lms/puck. Any embedded
// rich-text HTML inside that document is sanitized on write (same policy as
// blog posts), so a stored-XSS payload never reaches a logged-out visitor.

enum PageStatus {
  DRAFT
  PUBLISHED
}

model Page {
  id          String     @id @default(cuid())
  slug        String     @unique // URL key at the site root: /:slug
  title       String
  data        Json       @default("{}") // Puck document: { content, root, zones }
  status      PageStatus @default(DRAFT)
  publishedAt DateTime?  // set when first published; drives public visibility
  authorId    String?
  author      Admin?     @relation(fields: [authorId], references: [id], onDelete: SetNull)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([status, publishedAt])
}

// ---------- Mailchimp-linked Forms ----------
// Admin-authored forms (configurable field builder) that subscribe submitters
// to a chosen Mailchimp audience. The Mailchimp API key/server prefix are the
// one-time encrypted Settings; each form picks its own audience. Submissions are
// stored locally too, so a Mailchimp hiccup never loses a lead.

enum FormStatus {
  ACTIVE
  INACTIVE
}

model Form {
  id                    String     @id @default(cuid())
  name                  String
  fields                Json       @default("[]") // FormFieldDef[] (builder output)
  mailchimpAudienceId   String? // Mailchimp list id this form subscribes to
  mailchimpAudienceName String? // cached name for admin list display
  doubleOptIn           Boolean    @default(false) // default: No
  updateExisting        Boolean    @default(true) // default: Yes
  tags                  String[]   @default([]) // applied to every subscriber
  successMessage        String? // shown after submit when no redirect
  redirectUrl           String? // optional redirect after a successful submit
  status                FormStatus @default(ACTIVE)
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  submissions FormSubmission[]
}

model FormSubmission {
  id              String   @id @default(cuid())
  formId          String
  form            Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  email           String? // extracted email, for quick reference
  data            Json     @default("{}") // all submitted field values
  mailchimpStatus String? // subscribed | pending | existing | failed | skipped
  createdAt       DateTime @default(now())

  @@index([formId, createdAt])
}

// ---------- Popups ----------
// Popups reuse the SAME visual editor (Puck) as Pages — `data` is the Puck
// document rendered by the shared @lms/puck block components inside a styled,
// positioned overlay. On top of the content they carry presentation settings
// (size/background/position/border/padding) and visibility targeting that
// decides WHERE the popup is shown: the member dashboard and/or specific CMS
// pages. Only ACTIVE popups are exposed to the public targeting endpoint.

enum PopupStatus {
  ACTIVE
  INACTIVE
}

// On-screen placement of the popup box.
enum PopupPosition {
  CENTER
  TOP
  BOTTOM
  TOP_LEFT
  TOP_RIGHT
  BOTTOM_LEFT
  BOTTOM_RIGHT
}

// How a popup targets CMS pages (independent of the dashboard toggle).
enum PopupPageMode {
  NONE // not shown on any CMS page
  ALL // shown on every CMS page
  INCLUDE // shown only on the pages listed in pageIds
  EXCLUDE // shown on every CMS page except those listed in pageIds
}

model Popup {
  id     String      @id @default(cuid())
  name   String
  data   Json        @default("{}") // Puck document (same editor as Pages)
  status PopupStatus @default(INACTIVE) // INACTIVE until the admin turns it on

  // ----- presentation settings -----
  width        String        @default("480px") // CSS length (e.g. 480px, 90%, auto)
  height       String        @default("auto")
  background   String        @default("#ffffff") // CSS color of the popup box
  position     PopupPosition @default(CENTER)
  borderColor  String        @default("#e2e8f0")
  borderRadius Int           @default(12) // px
  padding      Int           @default(24) // px

  // ----- visibility / targeting -----
  showOnDashboard Boolean       @default(false) // show on the member dashboard
  pageMode        PopupPageMode @default(NONE)
  pageIds         String[]      @default([]) // referenced Page ids for INCLUDE/EXCLUDE

  // ----- analytics counters (incremented by the public event endpoint) -----
  views      Int @default(0) // times shown
  clicks     Int @default(0) // clicks on a link/button inside (web)
  dismissals Int @default(0) // times closed

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------- Media Library (Gallery) ----------
// Admin-managed catalog of uploaded files of ANY type (images, video, audio,
// PDF, docs, SVG…). Each asset is served at a stable PUBLIC URL so it can be
// embedded anywhere. `key` is the storage object key (local: filename under
// MEDIA_ROOT; cloud later: the bucket key) — the public URL is derived from it.
model MediaAsset {
  id           String   @id @default(cuid())
  key          String   @unique // storage key / stored filename
  originalName String // filename as uploaded (shown in the UI)
  mimeType     String
  size         Int // bytes
  width        Int? // images only
  height       Int? // images only
  title        String?
  altText      String?
  caption      String?
  description  String?
  uploadedById String?
  uploadedBy   Admin?   @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([createdAt])
}

// ---------- Admin in-app notifications ----------
// Server-emitted feed of billing/subscription events surfaced to admins via a
// bell in the admin app. Each row is an immutable snapshot (title/body rendered
// at emit time). Read state is PER-ADMIN via the AdminNotificationRead join, so
// every admin has their own unread count. `dedupeKey` is unique: the same
// logical event (incl. Stripe webhook replays) upserts to the same row, so the
// feed never double-counts. Emitted from BillingService.reconcileSubscription /
// handleWebhook (see apps/api/src/billing/billing.service.ts).

enum AdminNotificationType {
  SUBSCRIPTION_CREATED
  SUBSCRIPTION_CANCELED // immediate cancel OR Stripe's final auto-cancel (status -> CANCELED)
  SUBSCRIPTION_CANCEL_SCHEDULED // cancelAtPeriodEnd flipped true while still active
  SUBSCRIPTION_PAUSED
  SUBSCRIPTION_RESUMED
  PAYMENT_FAILED
  PAYMENT_SUCCEEDED // invoice.paid renewal (first invoice suppressed in favor of CREATED)
  INSTALLMENT_PLAN_COMPLETED // paid-in-full installment plan converted to lifetime
}

enum AdminNotificationSeverity {
  INFO
  WARNING
  CRITICAL
}

model AdminNotification {
  id        String                    @id @default(cuid())
  type      AdminNotificationType
  severity  AdminNotificationSeverity @default(INFO)
  title     String // short headline (rendered at emit time)
  body      String // one-line detail (member email + plan + amount)
  userId    String? // local User.id for deep-linking to /members/<userId>; no FK so history survives member deletion
  dedupeKey String                    @unique // idempotency key — same logical event upserts to the same row
  createdAt DateTime                  @default(now())

  reads AdminNotificationRead[]

  @@index([createdAt])
  @@index([type])
}

// Per-admin read marker. A notification is unread for an admin when no row
// exists for (notificationId, adminId) — the unread count is an anti-join.
model AdminNotificationRead {
  id             String            @id @default(cuid())
  notificationId String
  notification   AdminNotification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  adminId        String
  admin          Admin             @relation(fields: [adminId], references: [id], onDelete: Cascade)
  readAt         DateTime          @default(now())

  @@unique([notificationId, adminId])
  @@index([adminId])
}
