# Example per-instance env. The control-plane provisioner generates one of these
# per client (ports allocated, secrets minted) and writes it to
# deploy/instance/<id>.env. You can also copy it by hand to test locally:
#
#   cp deploy/instance/.env.instance.example deploy/instance/test.env
#   # edit ports + secrets, then:
#   docker compose -p lms_test --env-file deploy/instance/test.env \
#     -f deploy/instance/docker-compose.instance.yml up -d
#
# Reachable after boot:
#   API   → http://localhost:${API_PORT}/health
#   Web   → http://localhost:${WEB_PORT}
#   Admin → http://localhost:${ADMIN_PORT}   (login with SEED_ADMIN_*)

# ---- Published host ports (must be unique per instance on this host) ----
API_PORT=8010
WEB_PORT=8011
ADMIN_PORT=8012

# ---- Database (runs inside this instance's own postgres container) ----
POSTGRES_USER=postgres
POSTGRES_DB=lms
# Generate: openssl rand -hex 24
POSTGRES_PASSWORD=change-me-db-password

# ---- Secrets (unique per instance) ----
# Generate: openssl rand -hex 32
JWT_SECRET=change-me-64-hex-chars
# Generate: openssl rand -base64 32
SETTINGS_ENC_KEY=change-me-base64-32-bytes

# ---- First admin (created by the seed on first boot) ----
SEED_ADMIN_EMAIL=owner@client.example
# Generate: openssl rand -base64 18
SEED_ADMIN_PASSWORD=change-me-admin-password
# Real client instances boot empty (no demo catalog). Set to "true" only for a
# demo/sandbox instance.
SEED_DEMO_CONTENT=false

# ---- Environment label (production keeps the security defaults fail-closed) ----
ENV_NAME=production

# ---- Optional image overrides (default to the locally-built tags) ----
# API_IMAGE=lms-api:local
# WEB_IMAGE=lms-web:local
# ADMIN_IMAGE=lms-admin:local
