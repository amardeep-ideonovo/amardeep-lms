# =====================================================================
# Production environment for the VPS Docker deployment.
# Copy to deploy/.env and fill in. NEVER commit deploy/.env (gitignored).
#   cp deploy/.env.example deploy/.env
# =====================================================================

# ---- Your domain (no scheme, no trailing slash) ----
# DNS A records must point example.com, www, api, admin -> this server's IP.
DOMAIN=example.com

# Email for Let's Encrypt (cert expiry notices).
ACME_EMAIL=you@example.com

# ---- Public URLs (https, derived from DOMAIN) ----
# Baked into the web/admin client bundles at build time, and used for CORS.
PUBLIC_API_URL=https://api.example.com
WEB_APP_URL=https://example.com
# Comma-separated allowlist of browser origins allowed to call the API.
CORS_ORIGIN=https://example.com,https://admin.example.com

# ---- Postgres (runs in the `postgres` container) ----
POSTGRES_USER=postgres
POSTGRES_DB=lms
# CHANGE THIS. Generate one:  openssl rand -hex 24
POSTGRES_PASSWORD=change-me-strong-db-password

# ---- Auth / secrets ----
# Generate:  openssl rand -hex 32
JWT_SECRET=change-me-64-hex-chars
# Encryption key for the Settings table (32-byte base64).
# Generate:  openssl rand -base64 32
SETTINGS_ENC_KEY=change-me-base64-32-bytes
# Optional: gate public signup behind a shared code (leave blank to disable).
SIGNUP_INVITE_CODE=
# Optional rate-limit overrides (per IP per minute). Defaults: login 5, signup 3.
THROTTLE_LOGIN_LIMIT=
THROTTLE_SIGNUP_LIMIT=

# ---- Environment identifier (surfaced in /health and as Sentry tag) ----
# Pick one: production | staging | development. Defaults to production if unset.
ENV_NAME=production

# ---- Observability ----
# Sentry DSN. Leave blank to disable Sentry; no errors will be reported.
SENTRY_DSN=

# ---- Stripe (billing). Webhook URL = https://api.<DOMAIN>/billing/webhook ----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ---- Mux (video) ----
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
MUX_SIGNING_KEY_ID=
MUX_SIGNING_KEY_PRIVATE=
