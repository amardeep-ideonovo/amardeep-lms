# Public base URL of the NestJS API (no trailing slash).
NEXT_PUBLIC_API_URL=http://localhost:3000

# Public origin of THIS web app (no trailing slash). Used for canonical URLs,
# the sitemap, robots.txt, and absolute OpenGraph/Twitter tags. In production
# set this to the real domain, e.g. https://www.example.com
NEXT_PUBLIC_SITE_URL=http://localhost:3002

# Brand name shown in <title>, OpenGraph, and the web manifest.
NEXT_PUBLIC_SITE_NAME=LMS

# Optional: default meta description / OG description site-wide.
# NEXT_PUBLIC_SITE_DESCRIPTION=Courses, memberships, and resources for members.
