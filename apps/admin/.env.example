# Base URL of the NestJS API. Defaults to http://localhost:3000 if unset.
NEXT_PUBLIC_API_URL=http://localhost:3000

# Path prefix the admin is served under in production, e.g. "/admin". Must start
# with "/" and have NO trailing slash. This is a BUILD-TIME var (baked into the
# bundle + used by next.config.js basePath), so it must be set BEFORE `next build`,
# not just at runtime. Leave it UNSET for local dev (admin runs at the root of its
# dev port). Used by both next.config.js (routes + /_next assets) and
# lib/base-path.ts (raw window.location / window.open).
# NEXT_PUBLIC_ADMIN_BASE_PATH=/admin
