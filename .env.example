# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/lms?schema=public"

# Redis (BullMQ)
REDIS_URL="redis://localhost:6379"

# Encryption key for Setting secrets (32-byte base64)
SETTINGS_ENC_KEY=""

# Stripe (also editable at runtime via admin UI; these seed the Setting table)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# PayPal (also editable at runtime via admin UI; these seed the Setting table)
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
PAYPAL_WEBHOOK_ID=""         # from the app's webhook registration (needed to verify webhooks)
PAYPAL_MODE=""               # sandbox | live (default sandbox)

# API runtime
PORT="3000"                          # API listens here; clients default to http://localhost:3000
CORS_ORIGIN="http://localhost:3001,http://localhost:3002"  # admin, member web. REQUIRED in production — unset disables all cross-origin access.
WEB_APP_URL="http://localhost:3002"  # member web app — Stripe redirects back here
ENV_NAME="development"               # one of: development | staging | production. Unset = production (fail-safe). Surfaced in /health + Sentry tag.
TRUST_PROXY=""                       # set "1" (hop count) or "true" ONLY behind a CDN/LB; empty = X-Forwarded-* ignored

# Auth
JWT_SECRET=""                        # REQUIRED in production — the API refuses to boot without it
# Optional: if set, /auth/signup requires this exact code in the body to succeed.
# Use this if you want to soft-launch signup to a closed beta.
SIGNUP_INVITE_CODE=""
# Rate-limit overrides (per IP per minute). Defaults: login 5, signup 3,
# forgot-password 3.
THROTTLE_LOGIN_LIMIT=""
THROTTLE_SIGNUP_LIMIT=""
THROTTLE_FORGOT_LIMIT=""

# Observability — leave blank to disable Sentry entirely.
SENTRY_DSN=""

# WordPress migration (one-off; read-only MySQL access)
WP_DB_URL=""
WP_TABLE_PREFIX="wp_"
