{
  "name": "lms-monorepo",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "db:generate": "npm -w packages/db run generate",
    "db:migrate": "npm -w packages/db run migrate",
    "dev:api": "npm -w apps/api run dev",
    "dev:admin": "npm -w apps/admin run dev",
    "dev:web": "npm -w apps/web run dev"
  },
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-native": "0.74.5"
  }
}
